# ═══════════════════════════════════════════════════════════════════════
# HAYO AI — متغيرات البيئة وكلمات السر
# انسخ هذا الملف إلى .env واملأ القيم
# ═══════════════════════════════════════════════════════════════════════

# ─── قاعدة البيانات ───────────────────────────────────────────────────
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DBNAME

# ─── مفاتيح الذكاء الاصطناعي ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx          # Claude Opus 4.5/4.6
OPENAI_API_KEY=sk-xxxxxxxxxxxx                        # GPT-4o
GOOGLE_API_KEY3=AIzaSyxxxxxxxxxx                      # Gemini 2.5 Flash/Pro (المفتاح الصالح)
GEMINI_API_KEY=                                       # (اختياري — يُستخدم GOOGLE_API_KEY3 بدلاً منه)
GOOGLE_API_KEY=                                       # (منتهي الصلاحية — لا تستخدم)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx                      # DeepSeek Chat/Reasoner

# ─── تيليغرام ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:xxxxxxxxxxxx            # Bot1 — Trading Bot
TELEGRAM_BRIDGE_BOT_TOKEN=1234567890:xxxxxxxxxxxx     # Bot2 — Bridge Executive Bot
TELEGRAM_OWNER_CHAT_ID=34498339                       # Telegram Owner Chat ID (ثابت)

# ─── الجلسة والأمان ──────────────────────────────────────────────────
SESSION_SECRET=your-super-secret-session-key-here    # مفتاح تشفير الجلسات

# ─── Expo EAS (منشئ التطبيقات) ───────────────────────────────────────
EXPO_ACCESS_TOKEN=xxxxxxxxxx                          # من expo.dev → Account Settings → Access Tokens
EXPO_PROJECT_ID=4dfec6e4-f48a-456a-a168-e70849564e09  # Project ID من expo.dev (slug: hayo--04b69591)
EXPO_PROJECT_SLUG=hayo--04b69591                      # slug المسجّل على Expo
# EXPO_OWNER = ahmet80                                (ثابت في الكود)

# ─── OANDA (تداول) ───────────────────────────────────────────────────
OANDA_API_KEY=                                        # من OANDA Practice/Live Account
OANDA_ACCOUNT_ID=                                     # OANDA Account ID

# ─── Twelve Data (بيانات السوق) ──────────────────────────────────────
TWELVE_DATA_API_KEY=xxxxxxxxxx                        # من twelvedata.com

# ─── إعدادات عامة ────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=https://your-replit-domain.replit.app         # عنوان التطبيق المنشور

